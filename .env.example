# =================================
# ⚠️ SECURITY WARNING - IMPORTANT ⚠️
# =================================
# NEVER commit the .env file with real credentials to Git!
# This is a template file with placeholder values.
# Copy this file to .env and replace with your actual credentials.

# =================================
# ENVIRONMENT
# =================================
NODE_ENV=development
PORT=3000

# =================================
# DATABASE (Supabase PostgreSQL)
# =================================
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require
DATABASE_SSL=true

# =================================
# JWT AUTHENTICATION
# =================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secure-random-jwt-secret-here
JWT_EXPIRES_IN=24h

# Auth rate limiting (anti brute-force)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=20

# =================================
# STRIPE PAYMENT
# =================================
# TEST MODE (Development)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# LIVE MODE (Production - uncomment when ready)
# STRIPE_SECRET_KEY_LIVE=sk_live_your_stripe_live_secret_key
# STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_your_stripe_live_publishable_key

# =================================
# BRT API CONFIGURATION
# =================================
BRT_API_URL=https://api.brt.it/rest/v1
BRT_USER_ID=your_brt_user_id
BRT_PASSWORD=your_brt_password
BRT_DEPARTURE_DEPOT=your_departure_depot_code
BRT_SENDER_CUSTOMER_CODE=your_sender_customer_code

# BRT Pricing (ask your BRT account manager)
BRT_PRICING_CONDITION_CODE=000

# BRT Delivery Settings
BRT_DELIVERY_FREIGHT_TYPE=DAP
BRT_AUTO_CREATE_SHIPMENT=true
BRT_AUTO_CONFIRM=false
BRT_MANUAL_PICKUP=true
BRT_SERVICE_TYPE=

# =================================
# WAREHOUSE CONFIGURATION (Sender Address)
# =================================
WAREHOUSE_NAME=Your Warehouse Name
WAREHOUSE_COMPANY_NAME=Your Company S.r.l.
WAREHOUSE_STREET=Your Street Address
WAREHOUSE_CITY=Your City
WAREHOUSE_POSTAL_CODE=12345
WAREHOUSE_PROVINCE=XX
WAREHOUSE_COUNTRY=IT
WAREHOUSE_PHONE=+39xxxxxxxxxx
WAREHOUSE_EMAIL=warehouse@yourcompany.com

# =================================
# PACKAGE DEFAULT DIMENSIONS
# =================================
DEFAULT_PACKAGE_WEIGHT=0.5
DEFAULT_PACKAGE_LENGTH=20
DEFAULT_PACKAGE_WIDTH=15
DEFAULT_PACKAGE_HEIGHT=10

# =================================
# SUPABASE
# =================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret
SUPABASE_STORAGE_BUCKET=product-images

# =================================
# AWS S3 CONFIGURATION (For BRT Labels Storage)
# =================================
# NOTE: Supabase Storage is used instead of AWS S3. Commented out.
# AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_S3_BUCKET_LABELS=your-s3-bucket-name

# =================================
# AWS SES (Email Service)
# =================================
# NOTE: Resend is used as email provider. AWS SES commented out.
# AWS_SES_USE_IAM_ROLE=false
# AWS_SES_ACCESS_KEY_ID=your_ses_access_key_id
# AWS_SES_SECRET_ACCESS_KEY=your_ses_secret_access_key
# AWS_SES_REGION=eu-central-1

# =================================
# EMAIL CONFIGURATION
# =================================
EMAIL_PROVIDER=resend
EMAIL_BRAND_NAME=Your Brand
EMAIL_RATE_LIMIT_PER_SECOND=10
EMAIL_RETRY_ATTEMPTS=3
EMAIL_MAX_BATCH_SIZE=50

# Email Addresses
EMAIL_FROM=noreply@yourcompany.com
EMAIL_FROM_NAME=Your Store
EMAIL_ORDERS=orders@yourcompany.com
EMAIL_SUPPORT=support@yourcompany.com
EMAIL_INFO=info@yourcompany.com
EMAIL_ADMIN=admin@yourcompany.com

# RESEND API (Primary email provider)
RESEND_API_KEY=re_your_resend_api_key

# =================================
# REDIS & BULL QUEUE
# =================================
REDIS_HOST=your-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# Bull Queue Configuration (can use same Redis instance)
BULL_REDIS_HOST=your-redis-host.com
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=your_redis_password
BULL_REDIS_DB=0

# Queue Settings
QUEUE_CONCURRENCY_EMAIL=5
QUEUE_CONCURRENCY_SHIPMENT=3
QUEUE_CONCURRENCY_TRACKING=10
QUEUE_DEFAULT_JOB_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF_DELAY=5000

# =================================
# CRON JOBS
# =================================
# Tracking updates (every 2 hours)
CRON_TRACKING_UPDATE_ENABLED=true
CRON_TRACKING_UPDATE_SCHEDULE=0 */2 * * *

# Daily pickup (Mon-Fri at 4:00 PM)
CRON_PICKUP_SCHEDULE_ENABLED=true
CRON_PICKUP_SCHEDULE_TIME=0 16 * * 1-5

# Label download (every day at 10:00 AM)
CRON_LABEL_DOWNLOAD_ENABLED=true
CRON_LABEL_DOWNLOAD_SCHEDULE=0 10 * * *

# Daily Shipment Report Email
DAILY_SHIPMENT_REPORT_ENABLED=true
DAILY_SHIPMENT_REPORT_TIME=18:00
DAILY_SHIPMENT_REPORT_EMAILS=admin@yourcompany.com

# =================================
# FRONTEND
# =================================
FRONTEND_URL=http://localhost:4200

# Cookies
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# =================================
# RATE LIMITING
# =================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =================================
# API CONFIGURATION
# =================================
API_VERSION=v1

# =================================
# FILE STORAGE (Optional - for local label storage)
# =================================
LABELS_STORAGE_PATH=./storage/labels

# =================================
# LOGGING
# =================================
LOG_LEVEL=debug
LOG_FILE_PATH=./logs

# =================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =================================
# Before deploying to production:
# 1. ✅ Change NODE_ENV=production
# 2. ✅ Use STRIPE_SECRET_KEY_LIVE and STRIPE_PUBLISHABLE_KEY_LIVE
# 3. ✅ Update BRT_PRICING_CONDITION_CODE with production code from BRT
# 4. ✅ Set FRONTEND_URL to your actual domain (e.g., https://haraldicafirenze.com)
# 5. ✅ Set BRT_AUTO_CREATE_SHIPMENT=true if you want automatic shipment creation
# 6. ✅ Regenerate ALL secrets (JWT_SECRET, Stripe keys, AWS keys, Redis password)
# 7. ✅ Use AWS Secrets Manager or Parameter Store for production secrets
# 8. ✅ Enable DATABASE_SSL=true
# 9. ✅ Configure proper CORS origins in main.ts
# 10. ✅ Review and configure all CRON jobs for production schedule
