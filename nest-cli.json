{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "modules/public-api/utils/data/**/*",
      "modules/public-api/notifications/templates/**/*"
    ],
    "watchAssets": true
  }
}
