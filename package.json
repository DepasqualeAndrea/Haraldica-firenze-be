  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "setup:postman": "ts-node scripts/quick-test-setup.ts",
    "seed:admin": "ts-node scripts/seed-admin-user.ts",
    "create:admin": "ts-node -r tsconfig-paths/register scripts/create-admin-supabase.ts",
    "test:auth": "ts-node scripts/test-auth-flow.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:aws-ses": "ts-node -r tsconfig-paths/register scripts/test-aws-ses.ts",
    "test:email": "ts-node -r tsconfig-paths/register scripts/test-all-emails.ts",
    "test:redis": "ts-node -r tsconfig-paths/register scripts/test-redis.ts",
    "test:create-shipment": "ts-node -r tsconfig-paths/register scripts/test-create-shipment-for-order.ts",
    "seed:categories": "ts-node -r tsconfig-paths/register scripts/seed-categories.ts",
    "seed:products": "ts-node -r tsconfig-paths/register scripts/seed-products.ts",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate -d src/config/typeorm-cli.config.ts",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:run": "npm run typeorm -- migration:run -d src/config/typeorm-cli.config.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/config/typeorm-cli.config.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/config/typeorm-cli.config.ts"
  },
